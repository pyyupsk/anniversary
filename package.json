{
  "name": "anniversary",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "dev": "vite",
    "lint": "eslint .",
    "prepare": "nit install",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "nit": {
    "hooks": {
      "pre-commit": {
        "stages": {
          "**/*.{ts,vue}": "bunx eslint --fix {staged_files}"
        }
      },
      "commit-msg": "bunx commitlint --edit",
      "pre-push": "bun run typecheck"
    }
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/dm-mono": "^5.2.7",
    "@pyyupsk/fdu": "^0.0.0-beta.3",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@pyyupsk/eslint-config": "^0.3.0",
    "@pyyupsk/nit": "^0.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-unused": "^0.5.7",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.8",
    "vue-tsc": "^3.2.6"
  }
}
